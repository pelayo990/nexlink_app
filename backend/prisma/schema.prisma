generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  nombre        String
  email         String       @unique
  password      String
  rol           Rol
  avatar        String?
  marcaId       String?
  empresaId     String?
  colaboradorId String?
  createdAt     DateTime     @default(now())

  marca         Marca?       @relation(fields: [marcaId], references: [id])
  empresa       Empresa?     @relation(fields: [empresaId], references: [id])
  colaborador   Colaborador? @relation(fields: [colaboradorId], references: [id])
}

enum Rol {
  admin
  marca
  empresa
  colaborador
}

model Marca {
  id                       String     @id @default(cuid())
  nombre                   String
  logo                     String?
  categoria                String
  descripcion              String?
  contacto                 String?
  telefono                 String?
  rut                      String?    @unique
  estado                   Estado     @default(activo)
  plan                     Plan       @default(standard)
  fechaIngreso             DateTime   @default(now())
  totalProductosPublicados Int        @default(0)
  totalEventos             Int        @default(0)
  ventasTotales            Float      @default(0)
  colaboradoresAlcanzados  Int        @default(0)
  tasaConvercion           Float      @default(0)

  usuarios      User[]
  productos     Producto[]
  eventos       Evento[]
}

model Empresa {
  id                   String          @id @default(cuid())
  nombre               String
  rut                  String?         @unique
  industria            String
  logo                 String?
  contactoRRHH         String?
  emailRRHH            String?
  telefono             String?
  totalColaboradores   Int             @default(0)
  colaboradoresActivos Int             @default(0)
  estado               Estado          @default(activo)
  plan                 Plan            @default(standard)
  fechaIngreso         DateTime        @default(now())
  eventosParticipados  Int             @default(0)
  comprasTotales       Float           @default(0)
  ahorroColaboradores  Float           @default(0)
  satisfaccion         Float           @default(0)

  usuarios              User[]
  colaboradores         Colaborador[]
  eventos               EventoEmpresa[]
}

model Colaborador {
  id           String    @id @default(cuid())
  empresaId    String
  nombre       String
  email        String    @unique
  cargo        String?
  area         String?
  rut          String?   @unique
  fechaIngreso DateTime  @default(now())
  estado       Estado    @default(activo)
  puntos       Int       @default(0)

  empresa      Empresa   @relation(fields: [empresaId], references: [id])
  usuarios     User[]
  compras      Compra[]
}

model Evento {
  id                       String          @id @default(cuid())
  marcaId                  String
  nombre                   String
  descripcion              String?
  banner                   String?
  fechaInicio              DateTime
  fechaFin                 DateTime
  estado                   EstadoEvento    @default(proximo)
  destacado                Boolean         @default(false)
  tipo                     String          @default("flash")
  maxComprasPorColaborador Int             @default(2)
  totalVisitas             Int             @default(0)
  totalCompras             Int             @default(0)
  montoTotal               Float           @default(0)
  colaboradoresUnicos      Int             @default(0)

  marca      Marca           @relation(fields: [marcaId], references: [id])
  productos  Producto[]
  empresas   EventoEmpresa[]
  compras    Compra[]
}

model EventoEmpresa {
  eventoId  String
  empresaId String

  evento    Evento  @relation(fields: [eventoId], references: [id])
  empresa   Empresa @relation(fields: [empresaId], references: [id])

  @@id([eventoId, empresaId])
}

model Producto {
  id             String    @id @default(cuid())
  marcaId        String
  eventoId       String?
  nombre         String
  descripcion    String?
  categoria      String
  precioOriginal Float
  precioEvento   Float
  descuento      Float     @default(0)
  stock          Int       @default(0)
  stockMinimo    Int       @default(0)
  imagen         String?
  estado         Estado    @default(activo)
  sku            String?   @unique
  condicion      String    @default("nuevo")
  tags           String[]
  visitas        Int       @default(0)

  marca    Marca     @relation(fields: [marcaId], references: [id])
  evento   Evento?   @relation(fields: [eventoId], references: [id])
  compras  Compra[]
}

model Compra {
  id            String        @id @default(cuid())
  colaboradorId String
  productoId    String
  eventoId      String?
  fecha         DateTime      @default(now())
  monto         Float
  estado        EstadoCompra  @default(pendiente)

  colaborador   Colaborador   @relation(fields: [colaboradorId], references: [id])
  producto      Producto      @relation(fields: [productoId], references: [id])
  evento        Evento?       @relation(fields: [eventoId], references: [id])
}

enum Estado {
  activo
  pendiente
  inactivo
}

enum EstadoEvento {
  activo
  proximo
  finalizado
}

enum EstadoCompra {
  pendiente
  completada
  cancelada
}

enum Plan {
  standard
  premium
  enterprise
}
